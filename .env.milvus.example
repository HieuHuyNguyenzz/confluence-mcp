# Confluence Configuration
CONFLUENCE_URL=https://confluence.yourcompany.com
CONFLUENCE_API_TOKEN=your_api_token
CONFLUENCE_VERIFY_SSL=true

# Milvus Configuration
MILVUS_URL=http://localhost:19530
MILVUS_TOKEN=your_milvus_token
MILVUS_COLLECTION=confluence_knowledge

# Embedding API Configuration (used for both Semantic Chunking and Vector Storage)
EMBEDDING_API_URL=https://your-embedding-api.com/v1/embeddings
EMBEDDING_BATCH_SIZE=32

# Semantic Chunking Configuration
BREAKPOINT_THRESHOLD_TYPE=percentile
BREAKPOINT_THRESHOLD_AMOUNT=0.50

# Sync Configuration
# Leave empty to sync all spaces, or specify a space key (e.g., ENG)
SYNC_SPACE_KEY=
